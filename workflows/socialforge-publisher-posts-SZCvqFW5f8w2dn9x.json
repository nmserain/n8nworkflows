      "parameters": {
        "jsCode": "// PrÃ©parer la caption pour publication\nconst item = $input.item.json;\n\n// Combiner Texte + Hashtags\nconst texte = (item.Texte || '').trim();\nconst hashtags = (item.Hashtags || '').trim();\nconst caption = hashtags ? `${texte}\\n\\n${hashtags}` : texte;\n\n// Extraire l'URL du media\n// Media_URL peut Ãªtre une string directe ou un tableau Airtable\nlet mediaUrl = '';\nif (Array.isArray(item.Media_URL)) {\n  mediaUrl = item.Media_URL[0]?.url || item.Media_URL[0] || '';\n} else if (typeof item.Media_URL === 'string') {\n  mediaUrl = item.Media_URL;\n} else if (item.Media && Array.isArray(item.Media)) {\n  // Fallback: champ Media (attachment Airtable)\n  mediaUrl = item.Media[0]?.url || '';\n}\n\nreturn {\n  record_id: item.id || $input.item.json.id,\n  caption: caption,\n  media_url: mediaUrl,\n  texte: texte,\n  hashtags: hashtags,\n  date_publication: item.Date_Publication || '',\n  client_id: item.Client_ID || ''\n};"
