      "parameters": {
        "jsCode": "// Sélectionne une vidéo aléatoire parmi les résultats\nconst videos = $input.item.json.videos;\nconst randomIndex = Math.floor(Math.random() * Math.min(5, videos.length));\nconst selectedVideo = videos[randomIndex];\n\n// Trouve la meilleure qualité en portrait (1080x1920)\nconst portraitFile = selectedVideo.video_files.find(f => \n  f.width === 1080 && f.height === 1920\n) || selectedVideo.video_files.find(f => \n  f.width < f.height // Fallback: n'importe quel format portrait\n) || selectedVideo.video_files[0]; // Dernier recours: première vidéo\n\nreturn {\n  ...($input.item.json),\n  video_url: portraitFile.link,\n  video_duration: selectedVideo.duration,\n  video_id: selectedVideo.id\n};"
      },
