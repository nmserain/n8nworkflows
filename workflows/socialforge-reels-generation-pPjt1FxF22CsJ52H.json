      "parameters": {
        "jsCode": "// Parse la réponse Claude\nconst claudeResponse = $input.item.json.content[0].text;\nconst script = JSON.parse(claudeResponse);\n\n// Retourne les données structurées\nreturn {\n  hook: script.hook,\n  conseil: script.conseil,\n  cta: script.cta,\n  mots_cles_pexels: script.mots_cles_pexels,\n  texte_original: $('Lire Calendrier Google Sheets').item.json.Texte,\n  date_publication: $('Lire Calendrier Google Sheets').item.json.Date,\n  row_id: $('Lire Calendrier Google Sheets').item.json.__rowNum\n};"
      },
